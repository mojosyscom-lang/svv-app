create policy "company_assets_public_read"
on storage.objects
for select
to public
using (bucket_id = 'company-assets');

create policy "company_assets_owner_superadmin_insert"
on storage.objects
for insert
to authenticated
with check (
  bucket_id = 'company-assets'
  and exists (
    select 1
    from public.profiles p
    where p.id = auth.uid()
      and p.role in ('owner', 'superadmin')
  )
);

create policy "company_assets_owner_superadmin_update"
on storage.objects
for update
to authenticated
using (
  bucket_id = 'company-assets'
  and exists (
    select 1
    from public.profiles p
    where p.id = auth.uid()
      and p.role in ('owner', 'superadmin')
  )
)
with check (
  bucket_id = 'company-assets'
  and exists (
    select 1
    from public.profiles p
    where p.id = auth.uid()
      and p.role in ('owner', 'superadmin')
  )
);

create policy "company_assets_owner_superadmin_delete"
on storage.objects
for delete
to authenticated
using (
  bucket_id = 'company-assets'
  and exists (
    select 1
