drop policy if exists "company_profiles_owner_superadmin_insert" on public.company_profiles;
drop policy if exists "company_profiles_owner_superadmin_update" on public.company_profiles;
drop policy if exists "company_profiles_owner_superadmin_delete" on public.company_profiles;

create policy "company_profiles_superadmin_insert"
on public.company_profiles
for insert
to authenticated
with check (
  exists (
    select 1
    from public.profiles p
    where p.id = auth.uid()
      and p.company_id = company_profiles.company_id
      and p.role = 'superadmin'
  )
);

create policy "company_profiles_superadmin_update"
on public.company_profiles
for update
to authenticated
using (
  exists (
    select 1
    from public.profiles p
    where p.id = auth.uid()
      and p.company_id = company_profiles.company_id
      and p.role = 'superadmin'
  )
)
with check (
  exists (
    select 1
    from public.profiles p
    where p.id = auth.uid()
      and p.company_id = company_profiles.company_id
      and p.role = 'superadmin'
  )
);

create policy "company_profiles_superadmin_delete"
on public.company_profiles
for delete
to authenticated
using (
  exists (
    select 1
    from public.profiles p
    where p.id = auth.uid()
      and p.company_id = company_profiles.company_id
      and p.role = 'superadmin'
  )
);